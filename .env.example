# AI 与联网搜索
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key
# SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=your_brave_api_key

# 用户与管理员会话，请在部署环境改成长随机字符串
FORUM_SESSION_SECRET=replace_with_long_random_secret
FORUM_PHONE_HASH_SECRET=replace_with_another_long_random_secret

# 管理员密码，哈希优先；本地答辩演示也可使用 ADMIN_PASSWORD
ADMIN_PASSWORD_HASH=pbkdf2$sha256$310000$replace_with_salt$replace_with_hash
# ADMIN_PASSWORD=replace_with_demo_admin_password

# 可选 MySQL 配置，表结构见 mysql_schema.sql
MYSQL_URL=mysql://user:password@host:3306/database
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=job_compass
# MYSQL_PASSWORD=replace_with_mysql_password
# MYSQL_DATABASE=job_compass

HOST=127.0.0.1
PORT=4173
