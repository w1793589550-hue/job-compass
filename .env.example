DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your_tavily_api_key
# 或使用 Brave Search：
# SEARCH_PROVIDER=brave
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key
SEARCH_MAX_RESULTS=12
SOURCE_VERIFICATION_LIMIT=36
DAILY_TAVILY_CREDIT_QUOTA=40
# Tavily Researcher：US$30 / 1000 credits，按 1 USD = 7.1126 CNY 估算。
TAVILY_CREDIT_COST_CNY=0.213378
DEEPSEEK_INPUT_CACHE_HIT_CNY_PER_MILLION=0.2
DEEPSEEK_INPUT_CACHE_MISS_CNY_PER_MILLION=2
DEEPSEEK_OUTPUT_CNY_PER_MILLION=3
RATE_LIMIT_WINDOW_MS=600000
GENERATE_RATE_LIMIT=6
RESUME_RATE_LIMIT=12
FORUM_AUTH_RATE_LIMIT=20
FORUM_POST_RATE_LIMIT=10
FORUM_REPORT_RATE_LIMIT=12
# Use a salted PBKDF2 hash, not the plaintext admin password.
# Format: pbkdf2$sha256$iterations$saltBase64Url$hashBase64Url
ADMIN_PASSWORD_HASH=pbkdf2$sha256$310000$replace_with_salt$replace_with_hash
ADMIN_SESSION_SECRET=replace_with_long_random_secret
ADMIN_SESSION_TTL_MS=43200000
# Forum login sessions and phone hashing. Use long random strings in production.
FORUM_SESSION_SECRET=replace_with_another_long_random_secret
FORUM_SESSION_TTL_MS=2592000000
FORUM_PHONE_HASH_SECRET=replace_with_phone_hash_secret
PORT=4173
